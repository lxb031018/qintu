# ====================================================
# 云函数环境变量配置
# ====================================================
# 使用说明：
# 1. 复制此文件为 .env（cp .env.example .env）
# 2. 部署云函数时，这些变量会自动注入到函数环境中
# 3. 不要将此文件提交到版本库！
# ====================================================

# 数据库配置
DB_PASSWORD=your-database-password

# CloudBase Publishable Key
PUBLISHABLE_KEY=your-publishable-key

# AI 配置（可选）
AI_DEFAULT_AGENT=qwen
