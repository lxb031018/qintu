# 云函数环境变量配置示例
# 复制此文件为 .env 并填入实际值

# CloudBase 环境 ID
ENV_ID=qintu-cloudebase-5f5bpuj13bc6467

# MySQL 数据库配置
DB_HOST=your-mysql-host.ap-shanghai.tdsql.db.tencentcs.com
DB_PORT=3306
DB_USER=your-db-username
DB_PASSWORD=your-db-password
DB_NAME=qintu

# 高德地图 API Key（如果需要在后端调用）
AMAP_KEY=your-amap-key

# Node 环境
NODE_ENV=production
