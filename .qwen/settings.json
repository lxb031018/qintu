{
  "permissions": {
    "allow": [
      "Bash(tcb *)",
      "Bash(curl *)",
      "Bash(tccli *)",
      "Bash(icacls *)",
      "Bash(del *)",
      "Bash(dir *)",
      "Bash(timeout *)",
      "Bash(rmdir *)",
      "Bash(mkdir *)",
      "Bash(tar *)",
      "Bash(cloudbase *)",
      "Bash(npm install *)",
      "Bash(node *)",
      "Bash(flutter *)",
      "Bash(chcp *)",
      "Bash(type *)",
      "Bash(move *)",
      "Bash(findstr *)",
      "Bash(git checkout *)",
      "Bash(select-string *)",
      "Bash(select-object *)",
      "Bash(dart *)",
      "Bash(copy *)",
      "Bash(mcp__cloudbase__managefunctions *)",
      "mcp__cloudbase__auth",
      "mcp__cloudbase__callCloudApi",
      "Bash(git show *)",
      "Bash(echo.)",
      "Bash(jq *)",
      "Bash(ipconfig)",
      "Bash(taskkill *)",
      "Bash(netstat *)",
      "Bash(powershell *)",
      "Bash(true)"
    ]
  },
  "mcpServers": {
    "cloudbase": {
      "command": "npx",
      "args": [
        "@cloudbase/cloudbase-mcp@latest"
      ],
      "env": {
        "INTEGRATION_IDE": "CloudBaseCLI"
      }
    }
  },
  "$version": 3
}