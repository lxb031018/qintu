# ====================================================
# Qintu 应用环境配置文件
# ====================================================
# 使用说明：
# 1. 复制此文件为 .env（cp .env.example .env）
# 2. 根据实际情况修改下面的配置
# 3. .env 文件已被 .gitignore 忽略，不会提交到版本库
# ====================================================

# ----------------------------------------------------
# CloudBase 通用配置
# ----------------------------------------------------

# CloudBase 环境 ID（从 CloudBase 控制台获取）
CLOUDBASE_ENV_ID=qintu-cloudebase-5f5bpuj13bc6467

# CloudBase Publishable Key（用于客户端认证）
CLOUDBASE_PUBLISHABLE_KEY=your-publishable-key

# ----------------------------------------------------
# 本地开发环境配置（当前开发阶段使用）
# ----------------------------------------------------

# 本地服务器局域网 IP（电脑 IP 变化时需要同步更新）
# 查看方法：命令行运行 `ipconfig` 查找 IPv4 地址
LOCAL_SERVER_IP=192.168.99.106

# 本地服务器端口
LOCAL_SERVER_PORT=9000

# ----------------------------------------------------
# CloudBase 测试/生产环境配置
# ----------------------------------------------------

# CloudBase 网关路径（测试环境）
CLOUDBASE_TEST_GATEWAY_PATH=qintu-api-test

# CloudBase 网关路径（生产环境）
CLOUDBASE_PROD_GATEWAY_PATH=qintu-api

# ----------------------------------------------------
# 正式生产环境配置（上线后使用）
# ----------------------------------------------------

# 生产服务器域名（上线后替换为实际域名）
PRODUCTION_BASE_URL=https://api.qintu.com

# ----------------------------------------------------
# 高德地图 API Key
# ----------------------------------------------------

# Android 端高德地图 API Key
AMAP_ANDROID_API_KEY=your-amap-android-api-key

# iOS 端高德地图 API Key（如需要）
AMAP_IOS_API_KEY=your-amap-ios-api-key
